# Database URL (use postgresql+asyncpg for async SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://personas:personas@localhost:5432/personas

# Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key-here

# LLM Models
EMBED_MODEL=text-embedding-004
CHAT_MODEL=gemini-2.5-flash
SUMMARY_MODEL=gemini-2.5-pro

# Memory Tuning
SHORT_TERM_MESSAGES=12
SUMMARIZE_THRESHOLD=10
RETRIEVE_TOP_K=5

# Optional Third-Party Voice Providers
ELEVENLABS_API_KEY=
